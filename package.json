{
  "name": "buildora",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "npm run dev --prefix apps/web",
    "dev:api": "npm run dev --prefix apps/api",
    "build:web": "npm run build --prefix apps/web",
    "build:api": "npm run build --prefix apps/api",
    "install:all": "npm install --prefix packages/shared && npm install --prefix apps/api && npm install --prefix apps/web"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "concurrently": "^9.1.2"
  }
}
