{
  "name": "@buildora/shared",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/cjs/types.js",
  "module": "./dist/esm/types.js",
  "exports": {
    ".": {
      "types": "./dist/types.d.ts",
      "import": "./dist/esm/types.js",
      "require": "./dist/cjs/types.js"
    }
  },
  "types": "./dist/types.d.ts",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.types.json && tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json"
  },
  "dependencies": {
    "buildora": "file:../..",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
